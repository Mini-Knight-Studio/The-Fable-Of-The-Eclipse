                },
                {
                    "is_active": true,
                    "script": {
                        "class_id": "DialogTrigger",
                        "fields": {
                            "characterDelay": 0.029999999329447746,
                            "interactPrompt": "e2795b09-db39-592e-1d9d-de1810bed7af",
                            "nextCharSeparator": "/",
                            "textValue": "So... How strange it is to see a Solari finally leaving the safety of their lands./Step carefully on them, Prince, as it's been a long time since one of your kind has bothered to look at the ground beneath their feet/You pace among the burrows where my brothers and sisters hide from this waking nightmare./If you are quiet you may hear the heartbeat of the hundreds of sleeping warriors. Im the lucky one, though, the only one that will se you fail./Now, run along. The beasts have been waiting for someone to play with, and it would be a shame if you died too quickly.../it would be a very short story."
                        }
                    },
                    "uuid": "0758802c-86bb-52aa-4b11-e9a1237ea625"
                },
